# Copy this file to .env and fill in your values.
# Example:
#   cp .env.example .env

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
SMART_MODEL=qwen3.5:4b

# Identity
USER_NAME=User
ASSISTANT_NAME=Root

# Optional integrations
TELEGRAM_TOKEN=
OWNER_CHAT_ID=0
TAVILY_API_KEY=

# Optional Tavily overrides
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_TIMEOUT=20

# Allowed directories for the agent (path-separator separated)
# Linux/macOS example:
# ALLOWED_DIRS=/home/your-user/Projects:/home/your-user/Documents:/tmp/agent-workspace
# Windows example:
# ALLOWED_DIRS=C:\\Users\\your-user\\Projects;C:\\Users\\your-user\\Documents;C:\\temp\\agent-workspace
ALLOWED_DIRS=

# Optional platform hint for installer/runtime defaults
# Allowed values: linux, windows
PLATFORM_TARGET=
